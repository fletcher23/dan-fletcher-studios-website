---
import Layout from '@/layouts/Layout.astro';

/**
 * Form powered by Formspree.
 * 1. Sign up at formspree.io (free tier works fine)
 * 2. Create a new form and copy your form endpoint ID (looks like: xabcdefg)
 * 3. Replace YOUR_FORMSPREE_ID below with that ID
 */
const FORMSPREE_ID = 'YOUR_FORMSPREE_ID';
---

<Layout
  title="Contact"
  description="Book a photography, video, or design session with Dan Fletcher Studios. Based in Wheaton, IL, available nationwide."
>

  <section class="section page-header">
    <div class="container">
      <span class="eyebrow">Get In Touch</span>
      <h1>Let's Work Together</h1>
      <div class="divider"></div>
      <p class="page-header__sub">
        Most inquiries get a response within one business day.
        Fill out the form and I'll reach out to talk through the details.
      </p>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container contact-grid">

      <!-- Form -->
      <div class="contact-form-wrap">
        <form
          id="contact-form"
          action={`https://formspree.io/f/${FORMSPREE_ID}`}
          method="POST"
          novalidate
        >
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name <span aria-hidden="true">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                autocomplete="name"
                required
                placeholder="Jane Smith"
              />
            </div>
            <div class="form-group">
              <label for="email">Email <span aria-hidden="true">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                required
                placeholder="jane@yourcompany.com"
              />
            </div>
          </div>

          <div class="form-group">
            <label for="service">Service <span aria-hidden="true">*</span></label>
            <div class="select-wrap">
              <select id="service" name="service" required>
                <option value="" disabled selected>What are you interested in?</option>
                <optgroup label="Headshots">
                  <option value="headshots-essential">Essential ($299)</option>
                  <option value="headshots-professional">Professional ($499)</option>
                  <option value="headshots-team">Team / Corporate (custom quote)</option>
                </optgroup>
                <optgroup label="Brand Photography">
                  <option value="brand-starter">Brand Starter ($699)</option>
                  <option value="brand-full-day">Brand Full Day ($1,499)</option>
                </optgroup>
                <optgroup label="Lifestyle">
                  <option value="lifestyle">Lifestyle Session ($399)</option>
                </optgroup>
                <optgroup label="Graphic Design">
                  <option value="design-single">Single Asset ($95)</option>
                  <option value="design-pack">Asset Pack, 3 assets ($249)</option>
                  <option value="design-campaign">Print Campaign, 6 assets ($449)</option>
                  <option value="design-logo">Logo and Identity ($599)</option>
                  <option value="design-refresh">Brand Refresh ($349)</option>
                </optgroup>
                <optgroup label="Retainer">
                  <option value="retainer-starter">Content Starter ($799/month)</option>
                  <option value="retainer-pro">Content Pro ($1,499/month)</option>
                </optgroup>
                <optgroup label="Video Add-Ons">
                  <option value="video-reel">Social Reel add-on (+$199)</option>
                  <option value="video-brand">Brand Video add-on (+$499)</option>
                </optgroup>
                <option value="not-sure">Not sure yet, let's talk</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="timeline">Ideal Timeline</label>
            <input
              type="text"
              id="timeline"
              name="timeline"
              placeholder="e.g. Next 2–3 weeks, ASAP, flexible..."
            />
          </div>

          <div class="form-group">
            <label for="message">Tell me about your project <span aria-hidden="true">*</span></label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              placeholder="What are the images for? Any specific vision, location preferences, or questions?"
            ></textarea>
          </div>

          <!-- Honeypot -->
          <input type="text" name="_gotcha" style="display:none;" tabindex="-1" autocomplete="off" />
          <input type="hidden" name="_subject" value="New inquiry from Dan Fletcher Studios" />
          <input type="hidden" name="_next" value="https://danfletcherstudios.com/contact?sent=1" />

          <div id="form-error" class="form-msg form-msg--error" role="alert" hidden>
            Something went wrong. Please try again or email me directly.
          </div>

          <button type="submit" class="btn btn-primary submit-btn" id="submit-btn">
            Send Inquiry
          </button>
        </form>

        <!-- Success state -->
        <div id="form-success" class="form-success" hidden>
          <span class="form-success__icon" aria-hidden="true">✓</span>
          <h3>Got it. I'll be in touch soon.</h3>
          <p>Expect a reply within one business day.</p>
          <a href="/" class="btn btn-outline" style="margin-top:1.5rem;">Back to Home</a>
        </div>
      </div>

      <!-- Sidebar info -->
      <aside class="contact-info">
        <div class="contact-info__block">
          <h3>Location</h3>
          <p>Wheaton, Naperville, and the greater Chicago suburbs. Downtown Chicago available upon request.</p>
        </div>
        <div class="contact-info__block">
          <h3>Response Time</h3>
          <p>Within one business day. Priority sessions can be arranged on short notice, just ask.</p>
        </div>
        <div class="contact-info__block">
          <h3>Email</h3>
          <a href="mailto:hello@danfletcherstudios.com" class="contact-info__link">
            hello@danfletcherstudios.com
          </a>
        </div>
        <div class="contact-info__block">
          <h3>Not Sure?</h3>
          <p style="margin-bottom:0.75rem; color:var(--gray-lt);">
            Check the <a href="/services" style="color:var(--red); border-bottom:1px solid currentColor;">services page</a> or reach out anyway. No pressure, no sales pitch.
          </p>
        </div>
      </aside>

    </div>
  </section>

</Layout>

<script>
  // Show success message if redirected back with ?sent=1
  if (new URLSearchParams(window.location.search).get('sent') === '1') {
    const form    = document.getElementById('contact-form')    as HTMLElement;
    const success = document.getElementById('form-success')    as HTMLElement;
    form.hidden    = true;
    success.hidden = false;
  }

  // Optional: client-side AJAX submission to avoid full-page redirect
  const form      = document.getElementById('contact-form')    as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn')      as HTMLButtonElement;
  const errorMsg  = document.getElementById('form-error')      as HTMLElement;
  const successEl = document.getElementById('form-success')    as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    errorMsg.hidden = true;

    try {
      const data = new FormData(form);
      const res  = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.hidden    = true;
        successEl.hidden = false;
      } else {
        throw new Error('Non-200');
      }
    } catch {
      errorMsg.hidden    = false;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Inquiry';
    }
  });
</script>

<style>
  .page-header h1 { font-size: clamp(2.5rem, 5vw, 4rem); }
  .page-header__sub {
    color: var(--gray-lt);
    max-width: 520px;
    font-size: 1.0625rem;
    margin-top: 1rem;
  }

  /* Layout */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 5rem;
    align-items: start;
  }

  /* Form */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--gray-lt);
  }
  label span { color: var(--red); }

  input,
  select,
  textarea {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    color: var(--white);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    padding: 0.875rem 1rem;
    width: 100%;
    outline: none;
    transition: border-color 0.15s;
    -webkit-appearance: none;
    appearance: none;
  }
  input::placeholder,
  textarea::placeholder { color: var(--gray); }
  input:focus,
  select:focus,
  textarea:focus { border-color: var(--red); }

  textarea { resize: vertical; min-height: 140px; }

  .select-wrap { position: relative; }
  .select-wrap::after {
    content: '▾';
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--gray);
    font-size: 0.875rem;
  }
  select { padding-right: 2.5rem; cursor: pointer; }
  select option { background: var(--black); }

  .submit-btn { width: 100%; justify-content: center; margin-top: 0.5rem; }
  .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .form-msg { padding: 0.875rem 1rem; font-size: 0.875rem; margin-bottom: 1rem; }
  .form-msg--error { background: rgba(223,35,35,0.1); border: 1px solid var(--red); color: var(--red); }

  /* Success */
  .form-success {
    text-align: center;
    padding: 4rem 2rem;
    border: 1px solid var(--border);
  }
  .form-success__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    background: rgba(223,35,35,0.1);
    border: 1px solid var(--red);
    color: var(--red);
    font-size: 1.5rem;
    margin: 0 auto 1.5rem;
  }
  .form-success h3 { font-size: 1.5rem; margin-bottom: 0.5rem; }
  .form-success p  { color: var(--gray-lt); }

  /* Sidebar */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .contact-info__block {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .contact-info__block:first-child { border-top: 1px solid var(--border); }

  .contact-info__block h3 {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 0.5rem;
  }

  .contact-info__block p {
    font-size: 0.9375rem;
    color: var(--gray-lt);
    line-height: 1.6;
  }

  .contact-info__link {
    font-size: 0.9375rem;
    color: var(--red);
    border-bottom: 1px solid currentColor;
    transition: opacity 0.15s;
  }
  .contact-info__link:hover { opacity: 0.75; }

  /* Responsive */
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
    .contact-info { order: -1; display: grid; grid-template-columns: repeat(2, 1fr); gap: 0 2rem; }
    .contact-info__block:first-child { border-top: none; }
  }
  @media (max-width: 600px) {
    .form-row { grid-template-columns: 1fr; }
    .contact-info { grid-template-columns: 1fr; }
  }
</style>
