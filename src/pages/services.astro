---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Services and Pricing"
  description="Photography, graphic design, and video services from Dan Fletcher Studios. Headshots, brand sessions, retainer packages, and design work for individuals and businesses in the Chicago area."
>

  <!-- Page header -->
  <section class="section page-header">
    <div class="container">
      <span class="eyebrow">What I Offer</span>
      <h1>Services and Pricing</h1>
      <div class="divider"></div>
      <p class="page-header__sub">
        Straightforward packages, no surprise fees. Not sure which fits? <a href="/contact">Send a message</a> and we will figure it out together.
      </p>
    </div>
  </section>

  <!-- ── PHOTOGRAPHY ─────────────────────────────────── -->
  <section id="photography" class="section discipline-section">
    <div class="container">
      <div class="discipline-label">
        <span class="eyebrow">Photography</span>
      </div>

      <!-- Headshots -->
      <div class="sub-section">
        <h2 class="sub-heading">Headshots</h2>
        <div class="pkg-grid" style="--cols:3">

          <div class="pkg-card">
            <div class="pkg-card__top">
              <h3>Essential</h3>
              <div class="pkg-card__price">$299</div>
              <div class="pkg-card__duration">45 min</div>
            </div>
            <ul class="pkg-card__list">
              <li>1 location, 2 outfit changes</li>
              <li>10 edited images</li>
              <li>30-day online gallery</li>
            </ul>
            <div class="pkg-card__ideal"><strong>Ideal for:</strong> LinkedIn refresh, actor headshot, single professional portrait</div>
            <a href="/contact" class="btn btn-outline">Book This Package</a>
          </div>

          <div class="pkg-card pkg-card--featured">
            <span class="pkg-card__badge">Most Popular</span>
            <div class="pkg-card__top">
              <h3>Professional</h3>
              <div class="pkg-card__price">$499</div>
              <div class="pkg-card__duration">90 min</div>
            </div>
            <ul class="pkg-card__list">
              <li>2 locations, 3 outfit changes</li>
              <li>25 edited images</li>
              <li>48-hour turnaround</li>
              <li>60-day online gallery</li>
            </ul>
            <div class="pkg-card__ideal"><strong>Ideal for:</strong> Speaker bios, press pages, executive profiles, actor and creative portfolios</div>
            <a href="/contact" class="btn btn-primary">Book This Package</a>
          </div>

          <div class="pkg-card">
            <div class="pkg-card__top">
              <h3>Team / Corporate</h3>
              <div class="pkg-card__price">Custom</div>
              <div class="pkg-card__duration">Half or full day</div>
            </div>
            <ul class="pkg-card__list">
              <li>On-site at your location</li>
              <li>Consistent lighting and style across all subjects</li>
              <li>5 to 10 edited images per person</li>
            </ul>
            <div class="pkg-card__ideal"><strong>Ideal for:</strong> Teams of 5+, company-wide refresh</div>
            <a href="/contact" class="btn btn-outline">Get a Quote</a>
          </div>

        </div>
      </div>

      <!-- Brand Photography -->
      <div class="sub-section">
        <h2 class="sub-heading">Brand Photography</h2>
        <div class="pkg-grid" style="--cols:2">

          <div class="pkg-card">
            <div class="pkg-card__top">
              <h3>Brand Starter</h3>
              <div class="pkg-card__price">$699</div>
              <div class="pkg-card__duration">2 hrs</div>
            </div>
            <ul class="pkg-card__list">
              <li>1 location</li>
              <li>30 edited images: product, lifestyle, and portrait mix</li>
            </ul>
            <div class="pkg-card__ideal"><strong>Ideal for:</strong> New businesses building their first image library</div>
            <a href="/contact" class="btn btn-outline">Book This Package</a>
          </div>

          <div class="pkg-card pkg-card--featured">
            <span class="pkg-card__badge">Most Popular</span>
            <div class="pkg-card__top">
              <h3>Brand Full Day</h3>
              <div class="pkg-card__price">$1,499</div>
              <div class="pkg-card__duration">6 hrs</div>
            </div>
            <ul class="pkg-card__list">
              <li>Multiple locations</li>
              <li>80+ edited images</li>
              <li>Behind-the-scenes content</li>
              <li>Priority turnaround</li>
              <li>Commercial license included</li>
            </ul>
            <div class="pkg-card__ideal"><strong>Ideal for:</strong> Established brands, website relaunches, campaign shoots</div>
            <a href="/contact" class="btn btn-primary">Book This Package</a>
          </div>

        </div>
      </div>

      <!-- Lifestyle -->
      <div class="sub-section">
        <h2 class="sub-heading">Lifestyle</h2>
        <div class="pkg-grid" style="--cols:1; max-width:420px">

          <div class="pkg-card">
            <div class="pkg-card__top">
              <h3>Lifestyle Session</h3>
              <div class="pkg-card__price">$399</div>
              <div class="pkg-card__duration">90 min</div>
            </div>
            <ul class="pkg-card__list">
              <li>1 to 2 locations, 2 outfit changes</li>
              <li>25 edited images</li>
            </ul>
            <div class="pkg-card__ideal"><strong>Ideal for:</strong> Personal brand, social content, actors and creatives building a portfolio</div>
            <a href="/contact" class="btn btn-outline">Book This Package</a>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ── GRAPHIC DESIGN ──────────────────────────────── -->
  <section id="design" class="section discipline-section discipline-section--alt">
    <div class="container">
      <div class="discipline-label">
        <span class="eyebrow">Graphic Design</span>
      </div>

      <!-- Print and Digital Assets -->
      <div class="sub-section">
        <h2 class="sub-heading">Print and Digital Assets</h2>
        <p class="sub-desc">Includes any combination of social graphics and templates, menus, flyers, postcards, signage, and digital and print-ready ad creative (CMYK, bleed-ready).</p>
        <div class="pkg-grid" style="--cols:3">

          <div class="pkg-card">
            <div class="pkg-card__top">
              <h3>Single Asset</h3>
              <div class="pkg-card__price">$95</div>
              <div class="pkg-card__duration">2 to 3 business days</div>
            </div>
            <ul class="pkg-card__list">
              <li>1 custom asset</li>
              <li>Social graphic, flyer, postcard, or similar</li>
              <li>Print-ready and digital formats</li>
            </ul>
            <a href="/contact" class="btn btn-outline">Get Started</a>
          </div>

          <div class="pkg-card pkg-card--featured">
            <span class="pkg-card__badge">Best Value</span>
            <div class="pkg-card__top">
              <h3>Asset Pack</h3>
              <div class="pkg-card__price">$249</div>
              <div class="pkg-card__duration">3 to 4 business days</div>
            </div>
            <ul class="pkg-card__list">
              <li>3 custom assets</li>
              <li>Any combination of asset types</li>
              <li>Print-ready and digital formats</li>
            </ul>
            <a href="/contact" class="btn btn-primary">Get Started</a>
          </div>

          <div class="pkg-card">
            <div class="pkg-card__top">
              <h3>Print Campaign</h3>
              <div class="pkg-card__price">$449</div>
              <div class="pkg-card__duration">5 to 7 business days</div>
            </div>
            <ul class="pkg-card__list">
              <li>6 custom assets</li>
              <li>CMYK, bleed-ready print files</li>
              <li>Digital versions included</li>
            </ul>
            <a href="/contact" class="btn btn-outline">Get Started</a>
          </div>

        </div>
      </div>

      <!-- Branding -->
      <div class="sub-section">
        <h2 class="sub-heading">Branding</h2>
        <div class="pkg-grid" style="--cols:2">

          <div class="pkg-card pkg-card--featured">
            <span class="pkg-card__badge">New Brand</span>
            <div class="pkg-card__top">
              <h3>Logo and Identity</h3>
              <div class="pkg-card__price">$599</div>
              <div class="pkg-card__duration">5 to 7 business days</div>
            </div>
            <ul class="pkg-card__list">
              <li>3 initial concepts, 2 revision rounds</li>
              <li>SVG, PNG, and PDF file formats</li>
              <li>Color palette and font guide</li>
            </ul>
            <div class="pkg-card__ideal"><strong>Ideal for:</strong> New businesses, rebrands, solo professionals</div>
            <a href="/contact" class="btn btn-primary">Get Started</a>
          </div>

          <div class="pkg-card">
            <div class="pkg-card__top">
              <h3>Brand Refresh</h3>
              <div class="pkg-card__price">$349</div>
              <div class="pkg-card__duration">4 to 5 business days</div>
            </div>
            <ul class="pkg-card__list">
              <li>Redesigned collateral using your existing brand</li>
              <li>Up to 4 updated assets: social templates, business card, header, or similar</li>
              <li>Print-ready and digital file delivery</li>
            </ul>
            <div class="pkg-card__ideal"><strong>Ideal for:</strong> Businesses with existing branding that needs a refresh</div>
            <a href="/contact" class="btn btn-outline">Get Started</a>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ── RETAINER PACKAGES ───────────────────────────── -->
  <section class="section retainer-section">
    <div class="container">
      <span class="eyebrow">Ongoing Content</span>
      <h2>Retainer Packages</h2>
      <div class="divider"></div>
      <p class="retainer-intro">
        For businesses that need consistent, high-quality content without managing multiple vendors.
        All retainer packages require a 3-month minimum commitment.
      </p>

      <div class="retainer-grid">

        <div class="retainer-card">
          <div class="retainer-card__header">
            <h3>Content Starter</h3>
            <div class="retainer-card__price">$799<span>/month</span></div>
          </div>
          <ul class="pkg-card__list">
            <li>1 shoot per month (2 hours)</li>
            <li>10 edited images</li>
            <li>2 custom graphics created from shoot assets</li>
            <li>Priority scheduling</li>
          </ul>
          <a href="/contact" class="btn btn-outline" style="margin-top:auto;">Get Started</a>
        </div>

        <div class="retainer-card retainer-card--featured">
          <div class="retainer-card__badge">Most Complete</div>
          <div class="retainer-card__header">
            <h3>Content Pro</h3>
            <div class="retainer-card__price">$1,499<span>/month</span></div>
          </div>
          <ul class="pkg-card__list">
            <li>2 shoots per month (2 hours each)</li>
            <li>25 edited images</li>
            <li>4 custom graphics created from shoot assets</li>
            <li>1 social reel (vertical video, Instagram and TikTok optimized)</li>
            <li>Priority turnaround</li>
          </ul>
          <a href="/contact" class="btn btn-primary" style="margin-top:auto;">Get Started</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── VIDEO ADD-ONS ───────────────────────────────── -->
  <section id="video" class="section addons-section">
    <div class="container">
      <span class="eyebrow">Video</span>
      <h2>Video Add-Ons</h2>
      <div class="divider"></div>
      <p class="sub-desc" style="margin-bottom:2rem;">
        Video services are available as add-ons to any photography session or retainer package.
      </p>

      <div class="addon-grid">

        <div class="addon-card">
          <div class="addon-card__left">
            <h3>Social Reel</h3>
            <p>1 to 3 vertical clips, platform-optimized for Instagram and TikTok. Shot and edited during or alongside your photography session.</p>
          </div>
          <div class="addon-card__right">
            <div class="addon-card__price">+$199 <span>per shoot</span></div>
            <a href="/contact" class="btn btn-outline">Add to Session</a>
          </div>
        </div>

        <div class="addon-card addon-card--featured">
          <div class="addon-card__left">
            <h3>Brand Video</h3>
            <p>1 to 2 minute edited brand video with 2 revision rounds, delivered as MP4 (web and social ready). Great for website hero sections and About Me pages.</p>
          </div>
          <div class="addon-card__right">
            <div class="addon-card__price">+$499</div>
            <a href="/contact" class="btn btn-primary">Add to Session</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── AVAILABILITY ────────────────────────────────── -->
  <section class="section availability-section">
    <div class="container availability-inner">
      <div>
        <span class="eyebrow">Availability and Booking</span>
        <h2>When and where</h2>
        <div class="divider"></div>
        <p>Shoots are available weeknights and weekends. Design and editing work is completed on a flexible schedule with agreed turnaround times.</p>
        <p>Custom quotes available for all corporate, event, and multi-day projects.</p>
      </div>
      <div class="availability-details">
        <div class="avail-item">
          <h4>Service Area</h4>
          <p>Wheaton, Naperville, and the greater Chicago suburbs. Downtown Chicago available upon request.</p>
        </div>
        <div class="avail-item">
          <h4>Shoot Days</h4>
          <p>Weeknights and weekends. Flexible scheduling available.</p>
        </div>
        <div class="avail-item">
          <h4>Design Turnaround</h4>
          <p>2 to 7 business days depending on package. Rush available upon request.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ────────────────────────────────────────── -->
  <section class="section faq-section">
    <div class="container">
      <span class="eyebrow">Common Questions</span>
      <h2>Before you reach out</h2>
      <div class="divider"></div>
      <div class="faq-grid">
        {[
          { q: 'Where are you located?', a: 'Based in Wheaton, IL, serving Wheaton, Naperville, and the greater Chicago suburbs. Downtown Chicago is available upon request.' },
          { q: 'How long until I get my photos?', a: 'Standard turnaround is 5 to 7 business days. The Professional headshot package includes 48-hour turnaround.' },
          { q: 'What should I wear?', a: 'Solid colors and simple patterns photograph best. I send a full prep guide after booking.' },
          { q: 'Do you do outdoor sessions?', a: 'Yes. Studio, on-location, and outdoor options are all available depending on the look you are after.' },
          { q: 'I am an actor. Do you do theatrical headshots?', a: 'Yes. Headshot sessions for actors use the same process: we talk about how you want to be seen, pick the right look, and make portraits that get you noticed.' },
          { q: 'Can I add video to my shoot?', a: 'Yes. A Social Reel (+$199) or Brand Video (+$499) can be added to any photography session.' },
          { q: 'What is the retainer commitment?', a: 'Retainer packages require a 3-month minimum. After that they run month to month. They are designed for businesses that want a consistent content partner.' },
          { q: 'Can I add images after the shoot?', a: 'Yes. Additional edited images are available a la carte after delivery.' },
        ].map(({ q, a }) => (
          <div class="faq-item">
            <h4>{q}</h4>
            <p>{a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container" style="text-align:center; max-width:600px; margin-inline:auto;">
      <span class="eyebrow">Ready?</span>
      <h2>Let's build something you are proud to share.</h2>
      <div class="divider" style="margin-inline:auto;"></div>
      <a href="/contact" class="btn btn-primary" style="margin-top:1rem;">Book a Session</a>
    </div>
  </section>

</Layout>

<style>
  .page-header h1 { font-size: clamp(2.5rem, 5vw, 4rem); }
  .page-header__sub {
    color: var(--gray-lt);
    max-width: 560px;
    font-size: 1.0625rem;
    margin-top: 1rem;
  }
  .page-header__sub a { color: var(--red); border-bottom: 1px solid currentColor; }

  /* Discipline sections */
  .discipline-section { padding-top: 0; }
  .discipline-section--alt { background: rgba(255,255,255,0.01); }
  .discipline-section--alt .container { padding-block: 0; }

  .discipline-label { margin-bottom: 2.5rem; }

  .sub-section { margin-bottom: 4rem; scroll-margin-top: calc(var(--nav-h) + 2rem); }
  .sub-section:last-child { margin-bottom: 0; }

  .sub-heading {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    margin-bottom: 0.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }

  .sub-desc {
    color: var(--gray-lt);
    font-size: 0.9375rem;
    max-width: 640px;
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  /* Anchor offset for fixed nav */
  #photography, #design, #video {
    scroll-margin-top: calc(var(--nav-h) + 1rem);
  }

  /* Package grid */
  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), 1fr);
    gap: 1.25rem;
    align-items: start;
  }
  @media (max-width: 900px) { .pkg-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .pkg-grid { grid-template-columns: 1fr; max-width: none !important; } }

  /* Package card */
  .pkg-card {
    position: relative;
    border: 1px solid var(--border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: rgba(255,255,255,0.01);
    transition: border-color 0.2s;
  }
  .pkg-card:hover { border-color: rgba(255,255,255,0.15); }
  .pkg-card--featured {
    border-color: var(--red);
    background: rgba(223,35,35,0.04);
  }
  .pkg-card__badge {
    position: absolute;
    top: -1px; right: 1.5rem;
    background: var(--red);
    color: var(--white);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
  }
  .pkg-card__top h3 {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-lt);
    margin-bottom: 0.75rem;
  }
  .pkg-card__price {
    font-family: var(--font-serif);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
  }
  .pkg-card__duration {
    font-size: 0.8125rem;
    color: var(--gray);
    margin-top: 0.35rem;
  }
  .pkg-card__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }
  .pkg-card__list li {
    font-size: 0.875rem;
    color: var(--gray-lt);
    padding-left: 1.25rem;
    position: relative;
  }
  .pkg-card__list li::before {
    content: '';
    position: absolute;
    left: 0; top: 0.55em;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--red);
    opacity: 0.7;
  }
  .pkg-card__ideal {
    font-size: 0.8125rem;
    color: var(--gray);
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }
  .pkg-card__ideal strong { color: var(--gray-lt); }

  /* Retainer section */
  .retainer-section {
    background: rgba(223,35,35,0.04);
    border-top: 1px solid rgba(223,35,35,0.15);
    border-bottom: 1px solid rgba(223,35,35,0.15);
  }
  .retainer-section h2 { font-size: clamp(1.75rem, 3vw, 2.5rem); }
  .retainer-intro {
    color: var(--gray-lt);
    max-width: 580px;
    font-size: 0.9375rem;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }
  .retainer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 700px) { .retainer-grid { grid-template-columns: 1fr; } }

  .retainer-card {
    border: 1px solid var(--border);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-height: 360px;
    position: relative;
    background: rgba(255,255,255,0.01);
  }
  .retainer-card--featured {
    border-color: var(--red);
    background: rgba(223,35,35,0.05);
  }
  .retainer-card__badge {
    position: absolute;
    top: -1px; right: 1.5rem;
    background: var(--red);
    color: var(--white);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
  }
  .retainer-card__header h3 {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-lt);
    margin-bottom: 0.5rem;
  }
  .retainer-card__price {
    font-family: var(--font-serif);
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
  }
  .retainer-card__price span {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    color: var(--gray);
  }

  /* Add-on section */
  .addons-section h2 { font-size: clamp(1.75rem, 3vw, 2.5rem); }
  .addon-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .addon-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem;
    border: 1px solid var(--border);
    border-bottom: none;
    transition: background 0.2s;
  }
  .addon-card:last-child { border-bottom: 1px solid var(--border); }
  .addon-card--featured { border-color: var(--red); border-bottom-color: var(--red); background: rgba(223,35,35,0.03); }
  .addon-card__left { flex: 1; }
  .addon-card__left h3 {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .addon-card__left p {
    font-size: 0.875rem;
    color: var(--gray-lt);
    line-height: 1.65;
    max-width: 520px;
  }
  .addon-card__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1rem;
    flex-shrink: 0;
  }
  .addon-card__price {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    white-space: nowrap;
  }
  .addon-card__price span {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--gray);
    display: block;
    text-align: right;
  }
  @media (max-width: 600px) {
    .addon-card { flex-direction: column; align-items: flex-start; }
    .addon-card__right { align-items: flex-start; }
  }

  /* Availability */
  .availability-section { border-top: 1px solid var(--border); }
  .availability-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }
  .availability-inner h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); }
  .availability-inner p { color: var(--gray-lt); font-size: 0.9375rem; line-height: 1.7; margin-top: 0.75rem; }
  .availability-details {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .avail-item {
