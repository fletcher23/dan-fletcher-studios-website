---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Home"
  description="Dan Fletcher Studios: photography, video, and graphic design in Wheaton, IL. Headshots for professionals and actors, brand sessions, logos, and more."
>

  <!-- ── Hero ─────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>
    <div class="container hero__content">
      <span class="eyebrow">Photography · Video · Design · Chicago Suburbs</span>
      <h1 class="hero__headline">
        Visual work that<br />
        <em class="hero__accent">builds your brand</em><br />
        from the ground up.
      </h1>
      <p class="hero__sub">
        Photography, video, and graphic design for professionals, actors,
        entrepreneurs, and growing companies. Headshots, brand sessions,
        logos, collateral, and social assets.
      </p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn-primary">Start a Project</a>
        <a href="/portfolio" class="btn btn-outline">View Work</a>
      </div>
    </div>
    <div class="hero__scroll" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <!-- ── Disciplines ──────────────────────────────────── -->
  <section class="section disciplines">
    <div class="container">
      <div class="disciplines__grid">

        <!-- Photography -->
        <div class="discipline">
          <span class="eyebrow">Photography</span>
          <h2>The right image<br />at the right moment.</h2>
          <div class="divider"></div>
          <p>
            Headshots, brand sessions, lifestyle photography, and video work
            for individuals and businesses. Whether you need a single great
            portrait or a full content shoot, it all starts with a conversation.
          </p>
          <ul class="discipline__list">
            <li>Headshots for professionals, executives, and actors</li>
            <li>Business brand sessions</li>
            <li>Lifestyle and team photography</li>
            <li>Video reels and brand video</li>
          </ul>
          <a href="/services#photography" class="btn btn-outline-red" style="margin-top:2rem;">Photography and Video Pricing →</a>
        </div>

        <!-- Photography sub-cards -->
        <div class="discipline__cards">
          {[
            { title: 'Headshots',      desc: 'Portraits for professionals, executives, actors, and creatives. LinkedIn, press kits, speaker bios, and more.' },
            { title: 'Brand Sessions', desc: 'On-location or studio shoots that tell your brand story across your website, social, and beyond.' },
            { title: 'Video',          desc: 'Brand video, reels, and short-form content. Available standalone or paired with a photo session.' },
          ].map(({ title, desc }) => (
            <div class="disc-card">
              <h3>{title}</h3>
              <p>{desc}</p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ── Design callout ───────────────────────────────── -->
  <section class="design-callout">
    <div class="container design-callout__inner">
      <div class="design-callout__text">
        <span class="eyebrow">Graphic Design</span>
        <h2>A brand that looks<br /><em>as good as it performs.</em></h2>
        <div class="divider"></div>
        <p>
          Logos, visual identities, social templates, and print collateral.
          Clean, strategic design work that carries the same intentionality
          as the photography, built to work across every touchpoint.
        </p>
        <ul class="discipline__list" style="margin-top:1.25rem;">
          <li>Logo &amp; brand identity</li>
          <li>Business cards, flyers &amp; print</li>
          <li>Social media templates &amp; assets</li>
          <li>Brand style guides</li>
        </ul>
        <div style="display:flex; gap:1rem; flex-wrap:wrap; margin-top:2rem;">
          <a href="/services#design" class="btn btn-primary">Design Pricing</a>
          <a href="/contact" class="btn btn-outline">Start a Project</a>
        </div>
      </div>
      <div class="design-callout__visual" aria-hidden="true">
        <div class="design-visual__grid">
          <div class="design-visual__block design-visual__block--lg">
            <span>Logo</span>
          </div>
          <div class="design-visual__block">
            <span>Brand Guide</span>
          </div>
          <div class="design-visual__block">
            <span>Social</span>
          </div>
          <div class="design-visual__block design-visual__block--accent">
            <span>Print</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Portfolio teaser ─────────────────────────────── -->
  <section class="section portfolio-teaser">
    <div class="container">
      <span class="eyebrow">Recent Work</span>
      <div class="portfolio-teaser__header">
        <h2>Photography + Design.</h2>
        <a href="/portfolio" class="btn btn-outline-red">Full Portfolio →</a>
      </div>
      <div class="portfolio-teaser__grid">
        <!-- Replace src with your actual images -->
        {Array.from({ length: 6 }).map((_, i) => (
          <div class="portfolio-thumb portfolio-thumb--placeholder">
            <span>Work {i + 1}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA strip ────────────────────────────────────── -->
  <section class="section cta-strip">
    <div class="container cta-strip__inner">
      <div>
        <span class="eyebrow">Let's Work Together</span>
        <h2>Need photography, video, design, or all three?</h2>
        <p>Serving Wheaton, Naperville, and the greater Chicago suburbs. Downtown Chicago available upon request. Most inquiries get a response within one business day.</p>
      </div>
      <div class="cta-strip__actions">
        <a href="/contact" class="btn btn-primary">Get in Touch</a>
        <a href="/services" class="btn btn-outline">See All Pricing</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ─── */
  .hero {
    position: relative;
    min-height: calc(100vh - var(--nav-h));
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(35,35,35,0.95) 40%, rgba(35,35,35,0.7) 100%),
      url('/hero-bg.jpg') center/cover no-repeat;
    z-index: 0;
  }

  .hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 80px,
        rgba(223,35,35,0.03) 80px,
        rgba(223,35,35,0.03) 81px
      );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 820px;
    padding-block: clamp(4rem, 10vh, 8rem);
  }

  .hero__headline {
    font-size: clamp(2.75rem, 7vw, 5.5rem);
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .hero__accent { font-style: italic; color: var(--red); }

  .hero__sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--gray-lt);
    max-width: 560px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }
  .hero__scroll span {
    display: block;
    width: 1px;
    height: 3rem;
    background: linear-gradient(to bottom, transparent, var(--red));
    animation: scrollLine 2s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ── Disciplines ─── */
  .disciplines__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .discipline h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-top: 0.5rem;
  }

  .discipline p {
    color: var(--gray-lt);
    font-size: 1rem;
    line-height: 1.8;
    margin-top: 1rem;
  }

  .discipline__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .discipline__list li {
    font-size: 0.875rem;
    color: var(--gray-lt);
    padding-left: 1.25rem;
    position: relative;
  }
  .discipline__list li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--red);
  }

  .discipline__cards {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .disc-card {
    padding: 1.75rem 2rem;
    border: 1px solid var(--border);
    border-bottom: none;
    transition: background 0.2s;
  }
  .disc-card:last-child { border-bottom: 1px solid var(--border); }
  .disc-card:hover { background: rgba(255,255,255,0.02); }

  .disc-card h3 {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .disc-card p {
    font-size: 0.875rem;
    color: var(--gray-lt);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .disciplines__grid { grid-template-columns: 1fr; gap: 3rem; }
  }

  /* ── Design callout ─── */
  .design-callout {
    background: rgba(223, 35, 35, 0.05);
    border-top: 1px solid rgba(223, 35, 35, 0.2);
    border-bottom: 1px solid rgba(223, 35, 35, 0.2);
    padding-block: var(--section-gap);
  }

  .design-callout__inner {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 5rem;
    align-items: center;
  }

  .design-callout__text h2 {
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    margin-top: 0.5rem;
  }
  .design-callout__text h2 em {
    font-style: italic;
    color: var(--red);
  }
  .design-callout__text p {
    color: var(--gray-lt);
    font-size: 1rem;
    line-height: 1.8;
    margin-top: 1rem;
    max-width: 480px;
  }

  /* Decorative design grid */
  .design-visual__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 200px 120px;
    gap: 0.75rem;
  }

  .design-visual__block {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray);
    transition: background 0.2s;
  }
  .design-visual__block:hover { background: rgba(255,255,255,0.06); }

  .design-visual__block--lg {
    grid-column: span 2;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    color: var(--gray-lt);
    background: rgba(255,255,255,0.02);
    /* Once you have a logo design sample, add: background-image: url('/images/design-sample.jpg'); background-size: cover; */
  }

  .design-visual__block--accent {
    background: rgba(223,35,35,0.08);
    border-color: rgba(223,35,35,0.2);
    color: rgba(223,35,35,0.6);
  }

  @media (max-width: 1000px) {
    .design-callout__inner { grid-template-columns: 1fr; }
    .design-callout__visual { display: none; }
  }

  /* ── Portfolio teaser ─── */
  .portfolio-teaser__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .portfolio-teaser__header h2 { font-size: clamp(2rem, 4vw, 3rem); }

  .portfolio-teaser__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .portfolio-thumb {
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .portfolio-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .portfolio-thumb:hover img { transform: scale(1.04); }

  .portfolio-thumb--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gray);
    background: repeating-linear-gradient(
      45deg,
      #2a2a2a,
      #2a2a2a 10px,
      #272727 10px,
      #272727 20px
    );
  }

  @media (max-width: 700px) { .portfolio-teaser__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 460px) { .portfolio-teaser__grid { grid-template-columns: 1fr; } }

  /* ── CTA strip ─── */
  .cta-strip {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: rgba(223, 35, 35, 0.04);
  }

  .cta-strip__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .cta-strip__inner h2 { font-size: clamp(1.75rem, 3vw, 2.5rem); margin-block: 0.5rem 1rem; }
  .cta-strip__inner p  { color: var(--gray-lt); max-width: 480px; font-size: 0.9375rem; }

  .cta-strip__actions { display: flex; gap: 1rem; flex-wrap: wrap; flex-shrink: 0; }
</style>
