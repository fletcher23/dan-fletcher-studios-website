---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="About"
  description="About Dan Fletcher, photographer, videographer, and designer based in Wheaton, IL. The person behind Dan Fletcher Studios."
>

  <section class="section page-header">
    <div class="container">
      <span class="eyebrow">The Person Behind the Lens</span>
      <h1>About</h1>
      <div class="divider"></div>
    </div>
  </section>

  <section class="section about-main">
    <div class="container about-main__grid">
      <div class="about-main__photo">
        <!--
          Replace with your actual photo:
          <img src="/images/dan-fletcher.jpg" alt="Dan Fletcher" />
        -->
        <div class="about-main__photo-placeholder">
          <span>Your photo here</span>
        </div>
        <div class="about-main__photo-accent" aria-hidden="true"></div>
      </div>

      <div class="about-main__text">
        <h2>Hi, I'm Dan.</h2>
        <div class="divider"></div>
        <p>
          I'm a photographer, videographer, and graphic designer based in Wheaton, IL, working with professionals,
          actors, entrepreneurs, executives, and brands across Wheaton, Naperville, and the greater Chicago suburbs.
        </p>
        <p>
          I got into this work because I wanted to help people look and feel like the best version of themselves,
          and help businesses present themselves with the clarity and confidence they've earned. Good photography isn't
          just about a nice image. It is about telling the right story at the right moment.
        </p>
        <p>
          When I'm not shooting, I'm building software products, spending time with my family, and looking for the next
          interesting light.
        </p>

        <div class="about-stats">
          {[
            { num: 'Chicago',    label: 'Metro Area' },
            { num: '48 hrs',     label: 'Priority Turnaround' },
            { num: 'Nationwide', label: 'Travel Available' },
          ].map(({ num, label }) => (
            <div class="about-stat">
              <span class="about-stat__num">{num}</span>
              <span class="about-stat__label">{label}</span>
            </div>
          ))}
        </div>

        <a href="/contact" class="btn btn-primary" style="margin-top:2rem;">Work With Me</a>
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="section process-section">
    <div class="container">
      <span class="eyebrow">The Process</span>
      <h2>What working together looks like</h2>
      <div class="divider"></div>
      <div class="process-grid">
        {[
          { step: '01', title: 'Inquiry',     desc: 'Fill out the contact form or send an email. I respond within one business day to talk through what you\'re after.' },
          { step: '02', title: 'Consultation', desc: 'A quick call or email exchange to nail down the look, feel, location, and timing. No guesswork.' },
          { step: '03', title: 'The Session',  desc: 'I handle the direction. You just show up and I will guide you through every frame.' },
          { step: '04', title: 'Delivery',     desc: 'Edited images delivered to a private online gallery. Download, share, use them everywhere.' },
        ].map(({ step, title, desc }) => (
          <div class="process-step">
            <span class="process-step__num" aria-hidden="true">{step}</span>
            <h3>{title}</h3>
            <p>{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container" style="text-align:center; max-width:560px; margin-inline:auto;">
      <span class="eyebrow">Let's Go</span>
      <h2>Ready to get started?</h2>
      <div class="divider" style="margin-inline:auto;"></div>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:1.5rem;">
        <a href="/contact"  class="btn btn-primary">Book a Session</a>
        <a href="/services" class="btn btn-outline">See Pricing</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-header h1 { font-size: clamp(2.5rem, 5vw, 4rem); }

  /* About main */
  .about-main__grid {
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 5rem;
    align-items: start;
  }

  .about-main__photo { position: relative; }
  .about-main__photo-placeholder {
    aspect-ratio: 3/4;
    background: var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gray);
    background: repeating-linear-gradient(
      -45deg,
      #2a2a2a,
      #2a2a2a 10px,
      #272727 10px,
      #272727 20px
    );
  }
  .about-main__photo img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    display: block;
  }
  .about-main__photo-accent {
    position: absolute;
    bottom: -1rem;
    right: -1rem;
    width: 40%;
    height: 40%;
    border: 2px solid var(--red);
    z-index: -1;
  }

  .about-main__text h2 { font-size: clamp(2rem, 3.5vw, 3rem); }
  .about-main__text p {
    color: var(--gray-lt);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .about-stats {
    display: flex;
    gap: 2.5rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .about-stat { display: flex; flex-direction: column; gap: 0.25rem; }
  .about-stat__num {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--white);
  }
  .about-stat__label {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gray);
  }

  @media (max-width: 900px) {
    .about-main__grid { grid-template-columns: 1fr; gap: 3rem; }
    .about-main__photo { max-width: 420px; }
  }

  /* Process */
  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 2.5rem;
    position: relative;
  }

  .process-grid::before {
    content: '';
    position: absolute;
    top: 1.5rem;
    left: 2rem;
    right: 2rem;
    height: 1px;
    background: var(--border);
    z-index: 0;
  }

  .process-step { position: relative; z-index: 1; }

  .process-step__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    background: var(--black);
    border: 1px solid var(--red);
    color: var(--red);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .process-step h3 {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .process-step p {
    font-size: 0.875rem;
    color: var(--gray-lt);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .process-grid { grid-template-columns: repeat(2, 1fr); }
    .process-grid::before { display: none; }
  }
  @media (max-width: 500px) { .process-grid { grid-template-columns: 1fr; } }
</style>
